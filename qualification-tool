        .q-card.answered-green .q-answered-badge { display: inline; background: var(--green-bg); color: var(--green-dark); }
        .q-card.answered-green .q-answered-badge::after { content: '✓ Qualified'; }
        .q-card.answered-amber .q-answered-badge { display: inline; background: var(--amber-bg); color: var(--amber-dark); }
        .q-card.answered-amber .q-answered-badge::after { content: '⚠ Caution'; }
        .q-card.answered-red .q-answered-badge { display: inline; background: var(--red-bg); color: var(--red-dark); }
        .q-card.answered-red .q-answered-badge::after { content: '🔴 Standard'; }
