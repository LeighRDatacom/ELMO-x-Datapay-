        .info-panel-close:hover { background: var(--gray-bg); color: var(--text); }
        .info-panel-body { padding: 20px 24px 24px; }
        .ip-section { margin-bottom: 18px; }
        .ip-section:last-child { margin-bottom: 0; }
        .ip-section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: var(--text-muted); margin-bottom: 6px; }
        .ip-section-text { font-size: 13px; color: var(--text-sec); line-height: 1.65; }
        .ip-section-text strong { color: var(--text); }
        .ip-section-text ul { padding-left: 18px; margin-top: 6px; }
        .ip-section-text ul li { margin-bottom: 4px; }
        .ip-source { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 6px; background: var(--gray-bg); font-size: 11px; font-weight: 600; color: var(--text-muted); }

        .q-card { background: var(--white); border-radius: var(--radius-lg); border: 1px solid var(--border); padding: 22px 26px; margin-bottom: 10px; box-shadow: var(--shadow-sm); transition: all 0.2s ease; }
        .q-card.answered-green { border-color: var(--green-border); }
