function collectProgressData() {
    return {
        customerName: document.getElementById('custName').value || '',
        sellerName: document.getElementById('sellerName').value || '',
        qualDate: document.getElementById('qualDate').value || '',
        cautionNotes: document.getElementById('cautionNotes').value || '',
        nextStep: document.getElementById('nextStep').value || '',
        nextOwner: document.getElementById('nextOwner').value || '',
        escNotes: document.getElementById('escNotes').value || '',
        thresholds: thresholds,
        answers: answers,
        savedAt: new Date().toISOString(),
        version: 'v3.0'
    };
}

function saveProgress() {
    const data = collectProgressData();

    const customerNameInput = document.getElementById('custName').value.trim();

    // 🚫 Make Customer Name mandatory
    if (!customerNameInput) {
        alert('Please enter a Customer Name before saving progress.');
        document.getElementById('custName').focus();
        return;
    }

    // 🧼 Clean filename (remove weird characters)
    const safeCustomer = customerNameInput
        .replace(/[^a-z0-9\s-_]/gi, '')   // remove special chars
        .replace(/\s+/g, '_')            // spaces → underscores
        .toLowerCase();

    const date = data.qualDate || new Date().toISOString().split('T')[0];

    const filename = `${safeCustomer}_qualification_${date}.json`;

    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);

    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);

    alert(`Progress saved as:\n${filename}`);
}

function loadProgress(event) {
    const file = event.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = function(e) {
        try {
            const data = JSON.parse(e.target.result);
            applyProgressData(data);
            alert('Saved progress loaded successfully.');
        } catch (err) {
            console.error(err);
            alert('Could not load this file. Please make sure it is a valid saved progress file.');
        }
    };
    reader.readAsText(file);
}

function applyProgressData(data) {
    document.getElementById('custName').value = data.customerName || '';
    document.getElementById('sellerName').value = data.sellerName || '';
    document.getElementById('qualDate').value = data.qualDate || '';
    document.getElementById('cautionNotes').value = data.cautionNotes || '';
    document.getElementById('nextStep').value = data.nextStep || '';
    document.getElementById('nextOwner').value = data.nextOwner || '';
    document.getElementById('escNotes').value = data.escNotes || '';

    thresholds = Array.isArray(data.thresholds) ? data.thresholds : [null, null];
    answers = Array.isArray(data.answers) ? data.answers : new Array(questions.length).fill(null);

    renderQuestions();

    thresholds.forEach((val, idx) => {
        if (val) {
            setThreshold(idx, val, true);
        }
    });

    answers.forEach((answer, qi) => {
        if (!answer) return;

        const optionIndex = questions[qi].options.findIndex(o => o.tier === answer.tier && answer.label.includes(o.label));
        if (optionIndex === -1) return;

        const selectedOption = document.getElementById(`opt-${qi}-${optionIndex}`);
        const card = document.getElementById(`qcard-${qi}`);

        if (selectedOption) {
            selectedOption.classList.add('selected-' + answer.tier);
        }

        if (card) {
            card.classList.remove('answered-green','answered-amber','answered-red','answered-black');
            card.classList.add('answered-' + answer.tier);
        }
    });

    evaluate();
    document.getElementById('loadProgressFile').value = '';
}   



