}

       .info-btn:hover {
  background: #F59E0B !important;
  color: #fff !important;
  border-color: #F59E0B !important;
}

        .info-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(15,18,37,0.4); z-index: 200; align-items: center; justify-content: center; animation: fadeIn 0.2s ease; backdrop-filter: blur(2px); }
        .info-overlay.visible { display: flex; }
        .info-panel { background: var(--white); border-radius: var(--radius-lg); box-shadow: var(--shadow-lg); max-width: 520px; width: 92%; max-height: 85vh; overflow-y: auto; animation: slideUp 0.25s ease; }
        .info-panel-header { padding: 22px 24px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; gap: 12px; }
