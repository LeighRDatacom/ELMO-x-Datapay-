                let thresholds = [null, null];
        let answers = new Array(questions.length).fill(null);

        function renderQuestions() {
            const c = document.getElementById('questionsContainer');
            c.innerHTML = questions.map((q, qi) => {
                const opts = q.options.map((o, oi) => {
                    let tag = o.tier==='green'?'🟢 Qualified':o.tier==='amber'?'🟡 Caution':o.tier==='red'?'🔴 Standard':'⛔ Disqualify';
                    return `<div class="q-option" onclick="selectOption(${qi},${oi})" id="opt-${qi}-${oi}">
                        <div class="q-radio"><div class="q-radio-inner"></div></div>
                        <div style="flex:1;">
                            <div class="q-option-text">${o.label}</div>
                            ${o.note?`<div class="q-note">${o.note}</div>`:''}
                        </div>
                        <span class="q-option-tag ${o.tier}">${tag}</span>
                    </div>`;
                }).join('');
                const hasRed = q.options.some(o=>o.tier==='red');
                const hasBlack = q.options.some(o=>o.tier==='black');
                let stops = '';
                if(hasRed) stops+=`<div class="q-inline-stop red-stop">🔴 Not Qualified — route to Standard Datapay sales motion.</div>`;
                if(hasBlack) stops+=`<div class="q-inline-stop black-stop">⛔ Disqualified — not a fit for any current Datapay motion.</div>`;
                return `<div class="q-card" id="qcard-${qi}">
                    <div class="q-top">
                        <span class="q-num">${q.num}</span>
                        <div class="q-text">${q.text} 

${['q-complexity','q-contracts','q-multijob','q-effective','q-kiwisaver','q-transfers'].includes(q.infoKey) 
  ? `<button class="info-btn" onclick="event.stopPropagation();showInfo('${q.infoKey}')">⚠</button>` 
  : ''}



</div>
                        <span class="q-answered-badge"></span>
                    </div>
                    <div class="q-guidance">
                        <div class="q-guidance-block">
                            <div class="q-guidance-label">What we support</div>
                            <div class="q-guidance-text">${q.support}</div>
                        </div>
                        <div class="q-guidance-block">
                            <div class="q-guidance-label">What to confirm</div>
                            <div class="q-guidance-text">${q.confirm}</div>
                        </div>
                    </div>
                    <div class="q-prompt">
                        <div class="q-prompt-label">Suggested seller line</div>
