       function setThreshold(idx,val,isLoad=false) {
    thresholds[idx]=val;
    const card=document.getElementById(idx===0?'thresh1':'thresh2');
    card.querySelectorAll('.tc-btn').forEach(b=>b.classList.remove('active'));
    if(val==='yes'){
        card.querySelectorAll('.tc-btn')[0].classList.add('active');
        card.className='threshold-card passed';
    } else {
        card.querySelectorAll('.tc-btn')[1].classList.add('active');
        card.className='threshold-card failed';
    }
    evalThresholds();
    evaluate();
}

        function evalThresholds() {
            const stop=document.getElementById('thresholdStop'),qual=document.getElementById('qualSection');
            if(thresholds[0]===null||thresholds[1]===null){stop.classList.remove('visible');qual.classList.add('blocked');return;}
            if(thresholds[0]==='yes'&&thresholds[1]==='yes'){stop.classList.remove('visible');qual.classList.remove('blocked');}
            else{stop.classList.add('visible');qual.classList.add('blocked');}
        }

        function selectOption(qi,oi) {
            const q=questions[qi],opt=q.options[oi];
            answers[qi]={tier:opt.tier,label:q.text+': '+opt.label,num:q.num};
            q.options.forEach((_,oIdx)=>{document.getElementById(`opt-${qi}-${oIdx}`).classList.remove('selected-green','selected-amber','selected-red','selected-black');});
            document.getElementById(`opt-${qi}-${oi}`).classList.add('selected-'+opt.tier);
            const card=document.getElementById(`qcard-${qi}`);
            card.classList.remove('answered-green','answered-amber','answered-red','answered-black');
            card.classList.add('answered-'+opt.tier);
            evaluate();
        }

        function evaluate() {
            const total=2+questions.length;let done=0;
            if(thresholds[0]!==null)done++;if(thresholds[1]!==null)done++;
            answers.forEach(a=>{if(a!==null)done++;});
            const pct=Math.round((done/total)*100);
            document.getElementById('progFill').style.width=pct+'%';
            document.getElementById('progPct').textContent=pct+'%';
            const tFail=(thresholds[0]==='no'||thresholds[1]==='no');
            const tPass=(thresholds[0]==='yes'&&thresholds[1]==='yes');
            const hasBlack=answers.some(a=>a&&a.tier==='black');
            const hasRed=answers.some(a=>a&&a.tier==='red');
            const cautions=answers.filter(a=>a&&a.tier==='amber');
            const allAns=answers.every(a=>a!==null);
            const allGreen=allAns&&!hasRed&&!hasBlack&&cautions.length===0;
            const f=document.getElementById('progFill'),l=document.getElementById('liveResult');
            const rc=document.getElementById('resultCard'),ri=document.getElementById('rIcon'),rt=document.getElementById('rTitle'),rtx=document.getElementById('rText');
            const rC=document.getElementById('rCautions'),rCT=document.getElementById('rCautionsTitle'),rCL=document.getElementById('rCautionList');
            const rb=document.getElementById('routingBox');
            f.classList.remove('green','amber','red','black');rC.style.display='none';
            if(tFail){
                f.classList.add('red');l.className='live-result red';l.innerHTML='⛔ Route to Standard';
                rc.className='result-card red';ri.textContent='⛔';rt.textContent='Route to Standard Motion';
                rtx.textContent='Threshold gate failed. Route to Standard Datapay Opportunity.';
                rb.style.background='var(--red-bg)';rb.style.color='var(--red-dark)';rb.textContent='🔴 Route to Standard Motion';
                document.getElementById('cautionNotes').value='';document.getElementById('nextStep').value='Route to Standard Datapay Opportunity';return;
            }
            if(hasBlack){
                const bi=answers.filter(a=>a&&a.tier==='black');
                f.classList.add('black');l.className='live-result black';l.innerHTML='⛔ Disqualified';
                rc.className='result-card black';ri.textContent='🚫';rt.textContent='Disqualified — Not a Fit';
                rtx.textContent='This customer requires capability Datapay does not currently offer. Do not create an opportunity.';
                rC.style.display='block';rCT.textContent='⛔ Disqualifying Factors';
                rCL.innerHTML=bi.map(c=>'<li style="list-style:none;">'+c.num+': '+c.label+'</li>').join('');
                rb.style.background='#E0E1E9';rb.style.color='var(--black-dark)';rb.textContent='⛔ Disqualified — Not a Fit';
                document.getElementById('cautionNotes').value='DISQUALIFIED:\n'+bi.map(c=>c.num+': '+c.label).join('\n');
                document.getElementById('nextStep').value='No action — customer is not a fit';return;
            }
            if(hasRed){
                const ri2=answers.filter(a=>a&&a.tier==='red');
                f.classList.add('red');l.className='live-result red';l.innerHTML='🔴 Route to Standard';
                rc.className='result-card red';ri.textContent='🔴';rt.textContent='Route to Standard Motion';
                rtx.textContent=ri2.length+' item'+(ri2.length>1?'s':'')+' exceed Qualified scope. Route to standard motion.';
                rC.style.display='block';rCT.textContent='🔴 Items Requiring Standard Motion';
                rCL.innerHTML=ri2.map(c=>'<li style="list-style:none;">'+c.num+': '+c.label+'</li>').join('');
                rb.style.background='var(--red-bg)';rb.style.color='var(--red-dark)';rb.textContent='🔴 Route to Standard Motion';
                document.getElementById('cautionNotes').value='ROUTE TO STANDARD:\n'+ri2.map(c=>c.num+': '+c.label).join('\n');
                document.getElementById('nextStep').value='Route to Standard Datapay Opportunity';return;
            }
            if(!tPass||!allAns){
                const rem=total-done;l.className='live-result pending';l.innerHTML='⏳ '+rem+' remaining';
                rc.className='result-card inprogress';ri.textContent='🔍';rt.textContent='Qualification In Progress';
                rtx.textContent=rem+' item'+(rem>1?'s':'')+' remaining.';
                rb.style.background='var(--blue-bg)';rb.style.color='var(--blue-dark)';rb.textContent='⏳ '+rem+' remaining';return;
            }
            if(allGreen){
                f.classList.add('green');l.className='live-result green';l.innerHTML='🟢 Qualified — Proceed';
                rc.className='result-card green';ri.textContent='🎉';rt.textContent='Proceed as Qualified';
                rtx.textContent='All checks passed. No knockouts. No caution flags. Proceed to Lite Discovery.';
                rb.style.background='var(--green-bg)';rb.style.color='var(--green-dark)';rb.textContent='🟢 Qualified — Proceed to Lite Discovery';
                document.getElementById('cautionNotes').value='';document.getElementById('nextStep').value='Route to Lite Discovery';return;
            }
            f.classList.add('amber');l.className='live-result amber';l.innerHTML='🟡 Caution ('+cautions.length+')';
            rc.className='result-card amber';ri.textContent='⚠️';rt.textContent='Proceed with Caution';
            rtx.textContent=cautions.length+' caution flag'+(cautions.length>1?'s':'')+' identified. Route to Lite Discovery + pre-sales review.';
            rC.style.display='block';rCT.textContent='⚠ Caution Flags';
            rCL.innerHTML=cautions.map(c=>'<li>'+c.num+': '+c.label+'</li>').join('');
            rb.style.background='var(--amber-bg)';rb.style.color='var(--amber-dark)';rb.textContent='🟡 Proceed with Caution — Lite Discovery + PS Review';
            document.getElementById('cautionNotes').value='CAUTION:\n'+cautions.map(c=>c.num+': '+c.label).join('\n');
            document.getElementById('nextStep').value='Lite Discovery — flag caution items for pre-sales review';
        }

     function resetAll(){
    if(!confirm('Reset all? This cannot be undone.')) return;
    thresholds = [null, null];
    answers = new Array(questions.length).fill(null);
    document.querySelectorAll('.threshold-card').forEach(c => {
        c.className = 'threshold-card';
        c.querySelectorAll('.tc-btn').forEach(b => b.classList.remove('active'));
    });
    document.getElementById('thresholdStop').classList.remove('visible');
    document.getElementById('qualSection').classList.add('blocked');
    renderQuestions();
    ['custName','sellerName','cautionNotes','nextStep','nextOwner','escNotes'].forEach(id => {
        document.getElementById(id).value = '';
    });
    document.getElementById('qualDate').value = new Date().toISOString().split('T')[0];
    document.getElementById('loadProgressFile').value = '';
    evaluate();
}

