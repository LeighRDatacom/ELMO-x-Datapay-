        .q-option.selected-amber .q-option-text { color: var(--amber-dark); font-weight: 600; }
        .q-option.selected-red { border-color: var(--red); background: var(--red-bg); }
        .q-option.selected-red .q-radio { border-color: var(--red); }
        .q-option.selected-red .q-radio-inner { background: var(--red); opacity: 1; }
        .q-option.selected-red .q-option-text { color: var(--red-dark); font-weight: 600; }
        .q-option.selected-black { border-color: var(--black); background: var(--black-bg); }
