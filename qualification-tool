        .q-card.answered-black .q-inline-stop.black-stop { display: block; }
        .qual-section.blocked { opacity: 0.3; pointer-events: none; }
        .q-guidance { margin: 0 0 14px 38px; display: grid; gap: 10px; }
        .q-guidance-block { background: #f8fafc; border: 1px solid var(--border); border-radius: 12px; padding: 12px 14px; }
        .q-guidance-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.7px; color: var(--text-muted); margin-bottom: 4px; }
        .q-guidance-text { font-size: 13px; color: var(--text-sec); line-height: 1.55; }
        .q-guidance-text strong { color: var(--text); font-weight: 600; }
        .q-prompt { margin: 0 0 14px 38px; padding: 12px 14px; background: #eef6f7; border: 1px solid #d0e6e8; border-left: 4px solid #00a9b7; border-radius: 12px; }
        .q-prompt-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.7px; color: var(--text-muted); margin-bottom: 4px; }
        .q-prompt-text { font-size: 13px; color: var(--text); line-height: 1.55; }
        .q-prompt-text strong { font-weight: 600; }

        .result-section { margin-top: 28px; }
        .result-card { padding: 32px; border-radius: var(--radius-lg); text-align: center; transition: all 0.3s ease; }
