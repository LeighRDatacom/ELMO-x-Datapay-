        .q-option.selected-black .q-radio-inner { background: var(--black); opacity: 1; }
        .q-option.selected-black .q-option-text { color: var(--black-dark); font-weight: 600; }
        .q-note { margin-top: 6px; font-size: 11px; font-style: italic; color: var(--text-muted); line-height: 1.5; display: none; }
        .q-option.selected-amber .q-note { display: block; color: var(--amber-dark); opacity: 0.7; }
        .q-option.selected-red .q-note { display: block; color: var(--red-dark); opacity: 0.7; }
        .q-option.selected-black .q-note { display: block; color: var(--black-dark); opacity: 0.7; }
        .q-inline-stop { display: none; margin-top: 10px; padding: 12px 16px; border-radius: 10px; font-size: 12px; font-weight: 600; text-align: center; animation: fadeSlideIn 0.3s ease; }
